{
    "$schema":  "https://json-schema.org/draft/2020-12/schema",
    "$id":  "https://spec-docs.local/ai_workflow_mapper/config.schema.json",
    "title":  "AI Workflow Mapper Config",
    "type":  "object",
    "additionalProperties":  false,
    "required":  [
                     "environment",
                     "llm",
                     "storage",
                     "security"
                 ],
    "properties":  {
                       "environment":  {
                                           "type":  "string",
                                           "enum":  [
                                                        "local",
                                                        "staging",
                                                        "production"
                                                    ]
                                       },
                       "llm":  {
                                   "type":  "object",
                                   "required":  [
                                                    "provider",
                                                    "model"
                                                ],
                                   "additionalProperties":  true,
                                   "properties":  {
                                                      "provider":  {
                                                                       "type":  "string"
                                                                   },
                                                      "model":  {
                                                                    "type":  "string"
                                                                },
                                                      "max_cost_usd_per_job":  {
                                                                                   "type":  "number",
                                                                                   "minimum":  0
                                                                               }
                                                  }
                               },
                       "storage":  {
                                       "type":  "object",
                                       "additionalProperties":  true,
                                       "description":  "Database, file, object-storage, vector-store, and retention settings."
                                   },
                       "security":  {
                                        "type":  "object",
                                        "additionalProperties":  true,
                                        "description":  "Auth, RBAC, secret handling, and sensitive-data controls."
                                    },
                       "integrations":  {
                                            "type":  "object",
                                            "additionalProperties":  true
                                        },
                       "observability":  {
                                             "type":  "object",
                                             "additionalProperties":  true
                                         }
                   }
}
