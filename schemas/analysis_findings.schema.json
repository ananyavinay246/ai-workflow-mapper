{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec-docs.local/ai_workflow_mapper/analysis_findings.schema.json",
  "title": "Analysis Findings",
  "description": "Structured analysis report data; aligns with report_renderer template sections.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "executive_summary": { "type": "string" },
    "processes": {
      "type": "array",
      "items": { "$ref": "#/$defs/process_inventory_item" }
    },
    "bottlenecks": {
      "type": "array",
      "items": { "$ref": "#/$defs/bottleneck" }
    },
    "redundancies": {
      "type": "array",
      "items": { "$ref": "#/$defs/redundancy" }
    },
    "automation_opportunities": {
      "type": "array",
      "items": { "$ref": "#/$defs/automation_opportunity" }
    },
    "next_steps": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["quote", "source_filename"],
      "properties": {
        "quote": { "type": "string", "minLength": 1 },
        "source_filename": { "type": "string", "minLength": 1 },
        "char_start": { "type": "integer", "minimum": 0 },
        "char_end": { "type": "integer", "minimum": 0 }
      }
    },
    "process_inventory_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "owner": { "type": "string" },
        "duration": { "type": "string" },
        "frequency": { "type": "string" }
      }
    },
    "bottleneck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "severity", "description"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "severity": {
          "type": "string",
          "enum": ["Critical", "Moderate", "Minor"]
        },
        "description": { "type": "string" },
        "impact": { "type": "string" },
        "root_cause_hypothesis": { "type": "string" },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence" }
        }
      }
    },
    "redundancy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "description"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "waste_estimate": { "type": "string" },
        "affected_steps": {
          "type": "array",
          "items": { "type": "string" }
        },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence" }
        }
      }
    },
    "automation_opportunity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "effort": {
          "type": "string",
          "enum": ["Low", "Medium", "High"]
        },
        "roi": { "type": "string" },
        "priority": { "type": "string" },
        "time_savings_per_week": { "type": "string" },
        "suggested_approach": { "type": "string" },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence" }
        }
      }
    }
  }
}
