{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec-docs.local/ai_workflow_mapper/process_extraction.schema.json",
  "title": "Process Extraction",
  "description": "Structured LLM output before graph normalization. Passed to llm_adapter.complete_structured.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "steps": {
      "type": "array",
      "items": { "$ref": "#/$defs/extracted_step" }
    },
    "handoffs": {
      "type": "array",
      "items": { "$ref": "#/$defs/handoff" }
    },
    "decision_points": {
      "type": "array",
      "items": { "$ref": "#/$defs/decision_point" }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "extracted_step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "actor": { "type": "string" },
        "tool": { "type": "string" },
        "duration": { "type": "string" },
        "frequency": { "type": "string" },
        "sequence_order": { "type": "integer", "minimum": 0 },
        "uncertain": {
          "type": "boolean",
          "default": false,
          "description": "True when extraction confidence is low."
        }
      }
    },
    "handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from_step_id", "to_step_id"],
      "properties": {
        "from_step_id": { "type": "string", "minLength": 1 },
        "to_step_id": { "type": "string", "minLength": 1 },
        "from_actor": { "type": "string" },
        "to_actor": { "type": "string" }
      }
    },
    "decision_point": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step_id", "condition"],
      "properties": {
        "step_id": { "type": "string", "minLength": 1 },
        "condition": { "type": "string", "minLength": 1 },
        "true_branch_step_id": { "type": "string" },
        "false_branch_step_id": { "type": "string" }
      }
    }
  }
}
