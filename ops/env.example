# AI Workflow Mapper environment example
# Purpose: configuration checklist for local development and deployment planning.
# Remove unused variables during implementation and add project-specific integration keys as needed.
APP_ENV=local
LOG_LEVEL=info
TRACE_SAMPLE_RATE=1.0

# Supabase / deployed persistence
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
SUPABASE_STORAGE_BUCKET=

# LLM provider, set only for the provider selected by the implementation
LLM_PROVIDER=
LLM_MODEL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Add project-specific integration keys below.